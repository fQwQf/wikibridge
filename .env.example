# LLM Wiki server auth token (optional but recommended for production)
LLM_WIKI_TOKEN=change-me-in-production

# OpenCode server Basic auth password (optional).
# Leave empty or unset to disable login restrictions.
OPENCODE_SERVER_PASSWORD=

# Host port for the nginx gateway
WIKIBRIDGE_HTTP_PORT=80

# BearFRP public address used in generated frpc configs and public URLs.
# Set this to the server IP or domain before exposing tunnels outside localhost.
BEARFRP_PUBLIC_HOST=localhost

# BearFRP host ports
BEARFRP_BACKEND_PORT=8000
BEARFRP_BIND_PORT=7000
BEARFRP_HTTP_VHOST_PORT=8080
BEARFRP_TCP_PORT_START=50000
BEARFRP_TCP_PORT_END=50100

# Optional wildcard/subdomain host for HTTP proxies, for example apps.example.com.
# Leave empty to reuse BEARFRP_PUBLIC_HOST.
BEARFRP_SUBDOMAIN_HOST=

# BearFRP credentials and shared frps token. Change all of these in production.
BEARFRP_ADMIN_USERNAME=admin
BEARFRP_ADMIN_PASSWORD=change-me-in-production
BEARFRP_FRPS_ADMIN_USER=admin
BEARFRP_FRPS_ADMIN_PASSWORD=change-me-in-production
BEARFRP_FRPS_AUTH_TOKEN=change-me-in-production

# BearFRP user defaults
BEARFRP_FREE_RECHARGE_AMOUNT_MB=100
BEARFRP_DEFAULT_SPEED_LIMIT_KBPS=1024
BEARFRP_MAX_CONNECTIONS_PER_USER=3
BEARFRP_FRPS_VERSION=v0.58.1

# Automatic WikiBridge publishing frpc sidecar.
# The default TCP mode publishes nginx as http://<BEARFRP_PUBLIC_HOST>:<allocated-port>/.
WIKIBRIDGE_BEARFRP_USER=wikibridge
WIKIBRIDGE_BEARFRP_PASSWORD=wikibridge-change-me-in-production
WIKIBRIDGE_BEARFRP_PROXY_NAME=wikibridge
WIKIBRIDGE_BEARFRP_PROXY_TYPE=tcp
WIKIBRIDGE_BEARFRP_SUBDOMAIN=wikibridge
WIKIBRIDGE_BEARFRP_TRAFFIC_MB=100
WIKIBRIDGE_BEARFRP_SPEED_LIMIT_KBPS=1024
